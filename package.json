{
  "name": "unity-eslint-config",
  "version": "1.0.0",
  "description": "Shared ESLint flat configs for Unity JavaScript, TypeScript, Vue, and Node.js projects",
  "type": "module",
  "license": "MIT",
  "main": "./src/base.js",
  "bin": {
    "eslint": "./bin/eslint.js",
    "prettier": "./bin/prettier.js"
  },
  "exports": {
    ".": "./src/base.js",
    "./browser": "./src/browser.js",
    "./node": "./src/node.js",
    "./prettier": "./src/prettier.js",
    "./vue": "./src/vue.js",
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "lint": "node ./bin/eslint.js . --max-warnings=0"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^18.2.2",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "typescript-eslint": "^8.65.0",
    "vue-eslint-parser": "^10.4.1"
  },
  "peerDependencies": {
    "typescript": ">=4.8.4 <6.1.0"
  }
}
